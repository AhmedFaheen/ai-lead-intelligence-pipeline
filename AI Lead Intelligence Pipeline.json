      "parameters": {
        "promptType": "define",
        "text": "=You are an AI lead scoring and sales intelligence assistant.\n\nAnalyze the following lead using all available information, including website context.\n\nLead Information:\nCompany: {{$json[\"company\"]}}\nWebsite: {{$json[\"website\"]}}\nContact Name: {{$json[\"contact_name\"]}}\nRole: {{$json[\"role\"]}}\nNotes: {{$json[\"notes\"]}}\n\nWebsite Context:\nTitle: {{$json[\"website_title\"]}}\nDescription: {{$json[\"website_description\"]}}\n\nInstructions:\n- Evaluate how likely this lead is to convert (score 1–100)\n- Consider company relevance, role seniority, and intent signals from notes and website\n- Infer missing details if needed\n- Keep outputs concise and practical for sales outreach\n\nReturn ONLY valid JSON (no markdown, no explanations, no extra text):\n\n{\n  \"lead_score\": number,\n  \"confidence_score\": number (0-1),\n  \"rationale\": \"short explanation of scoring\",\n  \"value_proposition\": \"specific value tailored to this company\",\n  \"opening_line\": \"personalized outreach opener\",\n  \"objection_prediction\": \"likely objection from this lead\",\n  \"next_best_action\": \"recommended next step\"\n}",
        "batching": {}
