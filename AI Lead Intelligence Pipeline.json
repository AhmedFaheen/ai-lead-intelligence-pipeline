        "jsCode": "const itemsArr = items.map(i => i.json);\n\nreturn [{\n  json: {\n    total_leads: itemsArr.length,\n    avg_score: itemsArr.reduce((a,b)=>a + (b.lead_score || 0), 0) / itemsArr.length\n  }\n}];"
      },
